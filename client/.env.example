# BirdTag React Client - Environment Variables Template

# AWS Cognito Configuration
# Get these values from your AWS Cognito User Pool settings
VITE_COGNITO_DOMAIN=https://your-cognito-domain.auth.region.amazoncognito.com
VITE_COGNITO_CLIENT_ID=your_cognito_client_id_here
VITE_COGNITO_REDIRECT_URI=https://your-redirect-uri.com/callback
VITE_COGNITO_SCOPE=openid email profile
VITE_COGNITO_RESPONSE_TYPE=token

# AWS API Gateway
# Your backend API endpoint URL
VITE_API_GATEWAY_URL=https://your-api-gateway.execute-api.region.amazonaws.com/stage

# NOTE:
# - All variables must be prefixed with VITE_ to be accessible in the app
